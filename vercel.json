{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/v1/jobs?job=alerts",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/v1/jobs?job=all",
      "schedule": "30 9 * * 1-5"
    },
    {
      "path": "/api/v1/jobs?job=alerts",
      "schedule": "*/5 13-21 * * 1-5"
    },
    {
      "path": "/api/v1/jobs?job=tp_hits",
      "schedule": "*/5 13-21 * * 1-5"
    }
  ]
}
