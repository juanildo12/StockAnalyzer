{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/v1/jobs?job=all",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/morning-briefing/cron",
      "schedule": "0 6,10,14,18,22 * * *"
    }
  ]
}
