generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// NextAuth tables (required by @auth/supabase-adapter)
// ═══════════════════════════════════════════════════════════════════════════

model users {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      accounts[]
  sessions      sessions[]
  watchlists    watchlists[]
  portfolios    portfolios[]
  alerts        alerts[]
  subscriptions subscriptions?
  settings      user_settings?
  notifications notifications[]
  smartAlerts   smart_alerts[]

  @@map("users")
}

model accounts {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model sessions {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════
// Application tables
// ═══════════════════════════════════════════════════════════════════════════

model watchlists {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  symbol     String
  alertPrice Decimal? @map("alert_price") @db.Decimal(10, 2)
  alertType  String   @default("above") @map("alert_type")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("watchlists")
}

model portfolios {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  symbol        String
  shares        Decimal   @db.Decimal(10, 4)
  purchasePrice Decimal   @map("purchase_price") @db.Decimal(10, 2)
  purchaseDate  DateTime? @map("purchase_date")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

model alerts {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  symbol       String
  alertType    String    @map("alert_type")
  targetValue  Decimal?  @map("target_value") @db.Decimal(10, 2)
  currentValue Decimal?  @map("current_value") @db.Decimal(10, 2)
  status       String    @default("active")
  triggeredAt  DateTime? @map("triggered_at")
  message      String?
  createdAt    DateTime  @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model subscriptions {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  plan                 String    @default("free")
  status               String    @default("active")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ═══════════════════════════════════════════════════════════════════════════
// Market Data Cache (computed by background jobs)
// ═══════════════════════════════════════════════════════════════════════════

model stock_daily {
  symbol     String
  date       DateTime @db.Date
  open       Decimal? @db.Decimal(10, 2)
  high       Decimal? @db.Decimal(10, 2)
  low        Decimal? @db.Decimal(10, 2)
  close      Decimal? @db.Decimal(10, 2)
  volume     BigInt?
  changePct  Decimal? @db.Decimal(6, 2) @map("change_pct")

  @@id([symbol, date])
  @@map("stock_daily")
}

model stock_fundamentals {
  symbol           String   @id
  name             String?
  sector           String?
  industry         String?
  marketCap        BigInt?  @map("market_cap")
  peRatio          Decimal? @db.Decimal(8, 2) @map("pe_ratio")
  pegRatio         Decimal? @db.Decimal(8, 2) @map("peg_ratio")
  priceToBook      Decimal? @db.Decimal(8, 2) @map("price_to_book")
  dividendYield    Decimal? @db.Decimal(6, 4) @map("dividend_yield")
  roe              Decimal? @db.Decimal(6, 2)
  profitMargin     Decimal? @db.Decimal(6, 2) @map("profit_margin")
  revenueGrowth    Decimal? @db.Decimal(6, 2) @map("revenue_growth")
  earningsGrowth   Decimal? @db.Decimal(6, 2) @map("earnings_growth")
  debtToEquity     Decimal? @db.Decimal(8, 2) @map("debt_to_equity")
  fiftyTwoWeekHigh Decimal? @db.Decimal(10, 2) @map("fifty_two_week_high")
  fiftyTwoWeekLow  Decimal? @db.Decimal(10, 2) @map("fifty_two_week_low")
  avgVolume        BigInt?  @map("avg_volume")
  currentPrice     Decimal? @db.Decimal(10, 2) @map("current_price")
  changePct        Decimal? @db.Decimal(6, 2) @map("change_pct")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@map("stock_fundamentals")
}

// ═══════════════════════════════════════════════════════════════════════════
// Screener Results (pre-computed by background jobs)
// ═══════════════════════════════════════════════════════════════════════════

model screener_results {
  id            String   @id @default(cuid())
  screenerType  String   @map("screener_type")
  symbol        String
  score         Int
  rank          Int
  components    Json?
  levels        Json?
  reasons       Json?
  computedAt    DateTime @default(now()) @map("computed_at")

  @@unique([screenerType, symbol, computedAt])
  @@index([screenerType, computedAt(sort: Desc)])
  @@map("screener_results")
}

// ═══════════════════════════════════════════════════════════════════════════
// Morning Briefings (pre-computed daily)
// ═══════════════════════════════════════════════════════════════════════════

model morning_briefings {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  picks          Json
  marketContext  Json?    @map("market_context")
  summary        Json?
  computedAt     DateTime @default(now()) @map("computed_at")

  @@map("morning_briefings")
}

// ═══════════════════════════════════════════════════════════════════════════
// Signal History (for tracking win rates)
// ═══════════════════════════════════════════════════════════════════════════

model signal_history {
  id           String    @id @default(cuid())
  symbol       String
  signalType   String    @map("signal_type")
  score        Int?
  entryPrice   Decimal?  @db.Decimal(10, 2) @map("entry_price")
  targetPrice  Decimal?  @db.Decimal(10, 2) @map("target_price")
  stopPrice    Decimal?  @db.Decimal(10, 2) @map("stop_price")
  outcome      String?
  outcomePrice Decimal?  @db.Decimal(10, 2) @map("outcome_price")
  outcomeDate  DateTime? @db.Date @map("outcome_date")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([symbol, createdAt(sort: Desc)])
  @@map("signal_history")
}

// ═══════════════════════════════════════════════════════════════════════════
// Background Jobs (BullMQ)
// ═══════════════════════════════════════════════════════════════════════════

model job_runs {
  id          String   @id @default(cuid())
  jobType     String   @map("job_type")
  status      String   @default("running")
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  error       String?
  result      Json?

  @@index([jobType, startedAt(sort: Desc)])
  @@map("job_runs")
}

// ═══════════════════════════════════════════════════════════════════════════
// Smart Alerts (confluence-based)
// ═══════════════════════════════════════════════════════════════════════════

model smart_alerts {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  symbol       String
  score        Int
  grade        String

  entry        Decimal  @db.Decimal(10, 2)
  stopLoss     Decimal  @db.Decimal(10, 2) @map("stop_loss")
  tp1          Decimal  @db.Decimal(10, 2)
  tp2          Decimal  @db.Decimal(10, 2)
  riskReward   Decimal  @db.Decimal(5, 2)  @map("risk_reward")

  confidence   Int
  riskLevel    String   @map("risk_level")
  tradeTime    String   @map("trade_time")

  summary      String   @db.Text
  topFactors   Json     @map("top_factors")
  warnings     Json

  status       String   @default("active")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([symbol, status])
  @@map("smart_alerts")
}

// ═══════════════════════════════════════════════════════════════════════════
// Social Share Log
// ═══════════════════════════════════════════════════════════════════════════

model share_log {
  id        String   @id @default(cuid())
  alertId   String   @map("alert_id")
  symbol    String
  platform  String
  postId    String?  @map("post_id")
  postUrl   String?  @map("post_url")
  success   Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([alertId])
  @@index([platform, createdAt(sort: Desc)])
  @@map("share_log")
}

// ═══════════════════════════════════════════════════════════════════════════
// User Settings & Notifications
// ═══════════════════════════════════════════════════════════════════════════

model user_settings {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  emailAlerts     Boolean  @default(true) @map("email_alerts")
  breakoutAlerts  Boolean  @default(true) @map("breakout_alerts")
  priceAlerts     Boolean  @default(true) @map("price_alerts")
  morningBriefing Boolean  @default(true) @map("morning_briefing")
  alertFrequency  String   @default("realtime") @map("alert_frequency")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model notifications {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String
  title       String
  message     String
  data        Json?
  read        Boolean  @default(false)
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
